# Gembok Security Lockdown - v1.0
Options -Indexes

# Prevent directory browsing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Protect sensitive files and directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Block access to git directory
    RewriteRule ^\.git - [F,L]
    
    # Block access to private folders
    RewriteRule ^(includes|logs|cron|hooks|templates|objects|info|refs)/ - [F,L]
    
    # Block access to sensitive files
    RewriteRule ^(Dockerfile|config|description|HEAD|manifest\.json|packed-refs|start\.sh|install_cron\.sh|run_cron\.bat)$ - [F,L]
    
    # Block access to PHP files in includes and webhooks (except valid routing if any)
    # Actually webhooks/tripay.php needs to be accessible
    RewriteCond %{REQUEST_URI} ^/includes/.*\.php$
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# Block access to specific file extensions
<FilesMatch "\.(bak|conf|dist|fla|in[ci]|log|psd|sh|sql|sw[op]|env|sample|json|txt|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Exception for well-known and manifest
<FilesMatch "^(manifest\.json|sw\.js)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>
